# ── LLM API Keys ──────────────────────────────────────────────────────────────
# The system tries providers in this order: OpenRouter → Groq → Anthropic
# You only NEED one. OpenRouter is highly recommended for access to top free models.

# 1. OpenRouter (FREE models available — get key at openrouter.ai)
#    Has google/gemini-2.0-flash-exp:free and deepseek/deepseek-r1:free — no cost!
OPENROUTER_API_KEY=sk-or-...

# 2. Groq (FREE — fast fallback, get key at console.groq.com)
#    Free tier: 14,400 requests/day, 500K tokens/day
GROQ_API_KEY=gsk_...

# 3. Gemini / Anthropic (Optional PAID fallbacks if you don't use OpenRouter)
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-..

# ── Auth (keep true for local dev) ────────────────────────────────────────────
SKIP_AUTH=true
JWT_SECRET=change-this-in-production

# ── Service URLs (don't change for Docker) ────────────────────────────────────
# DOC_PARSER_URL=http://doc-parser:8002
# RAG_SERVICE_URL=http://rag-service:8001
# AGENT_ORCH_URL=http://agent-orchestrator:8000
