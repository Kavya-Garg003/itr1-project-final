# ── LLM API Keys ──────────────────────────────────────────────────────────────
# The system tries providers in this order: Groq → OpenRouter → OpenAI
# You only NEED one of the first two. OpenAI is a paid last resort.

# 1. Groq (FREE — best choice, get key at console.groq.com in 30 seconds)
#    Free tier: 14,400 requests/day, 500K tokens/day, no credit card
GROQ_API_KEY=gsk_...

# 2. OpenRouter (FREE models available — get key at openrouter.ai)
#    Has llama-3.3-70b:free, deepseek:free — no cost for free-tier models
OPENROUTER_API_KEY=sk-or-...

# 3. OpenAI (PAID — only used if both above fail or keys not set)
#    gpt-4o-mini costs ~$0.15/1M input tokens — very cheap, not free
OPENAI_API_KEY=sk-...

# ── Auth (keep true for local dev) ────────────────────────────────────────────
SKIP_AUTH=true
JWT_SECRET=change-this-in-production

# ── Service URLs (don't change for Docker) ────────────────────────────────────
# DOC_PARSER_URL=http://doc-parser:8002
# RAG_SERVICE_URL=http://rag-service:8001
# AGENT_ORCH_URL=http://agent-orchestrator:8000
